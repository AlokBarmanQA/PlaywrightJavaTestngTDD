<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Open Cart Test regression Playwright Suite" thread-count="2" parallel="tests" verbose="4">
	
	<listeners>
		<listener class-name="com.qa.opencart.listeners.ExtentReportListener"></listener>
	</listeners>
	
	<test name="Open Cart Home Page Test">
		<parameter name="browser" value="chromium"></parameter>
		<classes>
			<class name="com.qa.opencart.tests.HomePageTests" />
		</classes>
	</test>
</suite>
