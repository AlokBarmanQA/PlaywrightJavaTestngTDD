<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Open Cart Test Regression Suite" verbose="4" thread-count="5" parallel="tests">

 	<listeners>
		<listener
			class-name="com.qa.opencart.listeners.ExtentReportListener"></listener>
<!--		<listener
			class-name="com.qa.opencart.listeners.TestAllureListener"></listener>
		<listener
			class-name="com.qa.opencart.listeners.AnnotationTransformer"></listener> -->
	</listeners>
	<test name="Open Cart Home Page Test_chromium">
		<parameter name="browser" value="chromium"></parameter>
		<classes>
			<class name="com.qa.opencart.tests.HomePageTests" />
		</classes>
	</test>
	<test name="Open Cart Login Page Test_chrome">
		<parameter name="browser" value="chrome"></parameter>
		<classes>
			<class name="com.qa.opencart.tests.LoginPageTests" />
		</classes>
	</test>
	<test name="Open Cart Home Page Test_firefox">
		<parameter name="browser" value="firefox"></parameter>
		<classes>
			<class name="com.qa.opencart.tests.HomePageTests" />
		</classes>
	</test>
	<test name="Open Cart Login Page Test_edge">
		<parameter name="browser" value="edge"></parameter>
		<classes>
			<class name="com.qa.opencart.tests.LoginPageTests" />
		</classes>
	</test>
</suite>
